            Load = function(flag,d) if MergeUI.Options[flag] then MergeUI.Options[flag]:Set({CurrentValue=d.state}) end end
        },
        Slider = {
            Save = function(flag,d) return {type="Slider",flag=flag,value=tostring(d.CurrentValue)} end,
            Load = function(flag,d) if MergeUI.Options[flag] and d.value then MergeUI.Options[flag]:Set({CurrentValue=tonumber(d.value)}) end end
        },
