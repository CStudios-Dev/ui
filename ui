-- ─── Tween Helpers ───────────────────────────────────────────────────────────
local function Tween(obj, props, t, style, dir)
    local ti = TweenInfo.new(t or 0.35, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out)
    TweenService:Create(obj, ti, props):Play()
end

-- ─── Blur / Glass Effect ─────────────────────────────────────────────────────
local function CreateBlur(frame)
    local camera = workspace.CurrentCamera
    local part = Instance.new("Part", workspace)
    local dof  = Instance.new("DepthOfFieldEffect", Lighting)
    local surf = Instance.new("SurfaceGui", part)
    local mesh = Instance.new("BlockMesh", part)

    part.Material   = Enum.Material.Glass
    part.Transparency = 1
    part.Reflectance  = 1
    part.CastShadow   = false
    part.Anchored     = true
    part.CanCollide   = false
    part.CanQuery     = false
    part.Size         = Vector3.new(0.01, 0.01, 0.01)
    part.Color        = Color3.fromRGB(0,0,0)

    dof.Enabled        = true
    dof.FarIntensity   = 1
    dof.FocusDistance  = 0
    dof.InFocusRadius  = 500
    dof.NearIntensity  = 1

    surf.AlwaysOnTop = true
    surf.Adornee     = part
    surf.Active      = true
    surf.Face        = Enum.NormalId.Front

    local blurObj = { Enabled = true, Part = part, DOF = dof, Mesh = mesh }

    local function Hiter(pp, pn, ro, rd)
        local v = ro - pp
        local a = -((pn.x*v.x)+(pn.y*v.y)+(pn.z*v.z)) / ((pn.x*rd.x)+(pn.y*rd.y)+(pn.z*rd.z))
        return ro + a * rd
    end

    local function Update()
        if not blurObj.Enabled then
            Tween(part, {Transparency=1}, 0.5)
            return
        end
        Tween(part, {Transparency=0.8}, 0.5)
        local c0 = frame.AbsolutePosition
        local c1 = c0 + frame.AbsoluteSize
        local r0 = camera:ScreenPointToRay(c0.X, c0.Y, 1)
        local r1 = camera:ScreenPointToRay(c1.X, c1.Y, 1)
        local orig = camera.CFrame.Position + camera.CFrame.LookVector*(0.05 - camera.NearPlaneZ)
        local norm = camera.CFrame.LookVector
        local p0 = camera.CFrame:PointToObjectSpace(Hiter(orig,norm,r0.Origin,r0.Direction))
        local p1 = camera.CFrame:PointToObjectSpace(Hiter(orig,norm,r1.Origin,r1.Direction))
        local sz = p1 - p0
        mesh.Offset = (p0+p1)/2
        mesh.Scale  = sz / 0.0101
        part.CFrame = camera.CFrame
    end

    blurObj.Connection = RunService.RenderStepped:Connect(Update)
    blurObj.Update = Update
    blurObj.Destroy = function()
        blurObj.Connection:Disconnect()
        Tween(part, {Transparency=1}, 0.5)
        dof:Destroy()
        task.delay(0.6, function() part:Destroy() end)
    end

    return blurObj
end

-- ─── Utility ─────────────────────────────────────────────────────────────────
local function Kwargify(defaults, passed)
    passed = passed or {}
    for k,v in pairs(defaults) do
        if passed[k] == nil then passed[k] = v end
    end
    return passed
end

local function RemoveFromTable(t, val)
    for i,v in pairs(t) do
        if tostring(v) == tostring(val) then table.remove(t,i) return end
    end
end

local function UnpackTable(arr)
    local s, n = "", 0
    for _,v in pairs(arr) do
        n = n + 1
        if n <= 3 then s = s .. v .. ", " else return "Various" end
    end
    return s:sub(1,-3)
end

