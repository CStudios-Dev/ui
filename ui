    function Window:SaveConfig(name)
        local data = {objects={}}
        for flag,opt in pairs(MergeUI.Options) do
            if ClassParsers[opt.Class] and not opt.IgnoreConfig then
                table.insert(data.objects, ClassParsers[opt.Class].Save(flag,opt))
            end
        end
        local ok,enc = pcall(HttpService.JSONEncode, HttpService, data)
        if ok then writefile(cfg.ConfigFolder.."/configs/"..name..".json", enc) end
    end

    function Window:LoadConfig(name)
        local path = cfg.ConfigFolder.."/configs/"..name..".json"
        if not isfile(path) then return false end
        local ok,dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
        if not ok then return false end
        for _,obj in pairs(dec.objects) do
            if ClassParsers[obj.type] then task.spawn(function() ClassParsers[obj.type].Load(obj.flag,obj) end) end
        end
        return true
    end

    function Window:ListConfigs()
        local out = {}
        pcall(function()
            for _,f in ipairs(listfiles(cfg.ConfigFolder.."/configs")) do
                if f:sub(-5)==".json" then
                    local name = f:match("([^/\\]+)%.json$")
                    if name then table.insert(out, name) end
                end
            end
        end)
        return out
    end

