            Save = function(flag,d)
                local c = typeof(d.Color)=="Color3" and d.Color or Color3.new(1,1,1)
                return {type="Colorpicker",flag=flag,color=string.format("#%02X%02X%02X",c.R*255,c.G*255,c.B*255)}
            end,
            Load = function(flag,d)
                if MergeUI.Options[flag] and d.color then
                    local r = tonumber(d.color:sub(2,3),16)/255
                    local g = tonumber(d.color:sub(4,5),16)/255
                    local b = tonumber(d.color:sub(6,7),16)/255
                    MergeUI.Options[flag]:Set({Color=Color3.new(r,g,b)})
                end
            end
