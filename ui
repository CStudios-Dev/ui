            local ths = Instance.new("UIStroke", thumb); ths.Color = Color3.fromRGB(200,50,50); ths.Transparency = 0.4

            local interact = Instance.new("TextButton", track)
            interact.Size = UDim2.new(1,0,6,0); interact.Position = UDim2.new(0,-0,0,-16)
            interact.BackgroundTransparency = 1; interact.Text = ""; interact.ZIndex = 6

            local function SetVal(v, silent)
                v = math.floor(v / s.Increment + 0.5) * s.Increment
                v = math.clamp(v, s.Range[1], s.Range[2])
                local pct = (v - s.Range[1]) / (s.Range[2] - s.Range[1])
                valLbl.Text = tostring(v)
                SV.CurrentValue = v; s.CurrentValue = v
                Tween(fill, {Size=UDim2.new(pct,0,1,0)}, 0.08)
                Tween(thumb, {Position=UDim2.new(pct,0,0.5,0)}, 0.08)
                if not silent then pcall(s.Callback, v) end
            end
            SetVal(s.CurrentValue, true)
            pcall(s.Callback, s.CurrentValue)

            local dragging = false
            interact.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=true end
            end)
            interact.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=false end
            end)
            RunService.RenderStepped:Connect(function()
                if dragging then
                    local rel = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    local v = s.Range[1] + rel * (s.Range[2] - s.Range[1])
                    SetVal(v)
                end
            end)
            HoverEffect(f, us)
            function SV:UpdateValue(v) SetVal(v) end
            function SV:Set(n) n=Kwargify(s,n) s=n SetVal(s.CurrentValue,true) end
            function SV:Destroy() f:Destroy() end
            if flag then MergeUI.Options[flag] = SV end
            return SV
        end

        -- ── Input ─────────────────────────────────────────────────────────
        function Tab:CreateInput(s, flag)
            s = Kwargify({Name="Input",Description=nil,CurrentValue="",PlaceholderText="Type here...",Numeric=false,Enter=false,RemoveTextAfterFocusLost=false,MaxCharacters=nil,Callback=function()end}, s)
            local IV = {Class="Input",IgnoreConfig=false,CurrentValue=s.CurrentValue,Settings=s}
            local h = s.Description and 52 or 38
            local f,_,us = BaseFrame(h)
            TextEl(f, s.Name, 0.03, s.Description and 0.05 or 0.18, 0.45, s.Description and 0.35 or 0.65, true)
            if s.Description then TextEl(f, s.Description, 0.03, 0.52, 0.45, 0.35, false, 0.35) end

            local box = Instance.new("TextBox", f)
            box.AnchorPoint = Vector2.new(1,0.5); box.Position = UDim2.new(0.97,0,0.5,0)
            box.Size = UDim2.new(0.48,0,0.65,0); box.BackgroundColor3 = Color3.fromRGB(30,8,8)
            box.BackgroundTransparency = 0.4; box.BorderSizePixel = 0
            box.Font = Enum.Font.Gotham; box.Text = tostring(s.CurrentValue)
            box.PlaceholderText = s.PlaceholderText; box.TextColor3 = Color3.fromRGB(255,220,220)
            box.TextScaled = true; box.ClearTextOnFocus = false; box.ZIndex = f.ZIndex+3
            local bc = Instance.new("UICorner", box); bc.CornerRadius = UDim.new(0,4)
            local bst = Instance.new("UIStroke", box); bst.Color = Color3.fromRGB(160,20,20); bst.Transparency = 0.6

            box:GetPropertyChangedSignal("Text"):Connect(function()
                if s.Numeric and not tonumber(box.Text) and box.Text~="" and box.Text~="-" then
                    box.Text = box.Text:match("[%-0-9%.]*") or ""
                end
                if s.MaxCharacters and #box.Text > s.MaxCharacters then
                    box.Text = box.Text:sub(1, s.MaxCharacters)
                end
                IV.CurrentValue = box.Text
                if not s.Enter then pcall(s.Callback, box.Text) end
            end)
            box.FocusLost:Connect(function(enter)
                if s.Enter and enter then pcall(s.Callback, box.Text) end
                if s.RemoveTextAfterFocusLost then box.Text = "" end
            end)
            HoverEffect(f, us)
            function IV:Set(n) n=Kwargify(s,n) s=n box.Text=tostring(s.CurrentValue) IV.CurrentValue=s.CurrentValue end
            function IV:Destroy() f:Destroy() end
            if flag then MergeUI.Options[flag] = IV end
            return IV
        end

        -- ── Dropdown ──────────────────────────────────────────────────────
        function Tab:CreateDropdown(s, flag)
            s = Kwargify({Name="Dropdown",Description=nil,Options={},CurrentOption={},MultipleOptions=false,SpecialType=nil,Callback=function()end}, s)
            if type(s.CurrentOption)=="string" then s.CurrentOption={s.CurrentOption} end
            local DV = {Class="Dropdown",IgnoreConfig=false,CurrentOption=s.CurrentOption,Settings=s}

            local closedH = s.Description and 52 or 38
            local f,_,us = BaseFrame(closedH)
            TextEl(f, s.Name, 0.03, s.Description and 0.05 or 0.18, 0.6, s.Description and 0.35 or 0.65, true)
            if s.Description then TextEl(f, s.Description, 0.03, 0.52, 0.6, 0.35, false, 0.35) end

            local selLabel = Instance.new("TextLabel", f)
            selLabel.AnchorPoint = Vector2.new(1,0.5); selLabel.Position = UDim2.new(0.93,0,0.5,0)
            selLabel.Size = UDim2.new(0.32,0,0.55,0); selLabel.BackgroundTransparency = 1
            selLabel.Font = Enum.Font.Gotham; selLabel.TextScaled = true
            selLabel.TextColor3 = Color3.fromRGB(200,100,100); selLabel.TextTransparency = 0.3
            selLabel.Text = s.CurrentOption[1] or "None"; selLabel.TextXAlignment = Enum.TextXAlignment.Right

            local arrow = Instance.new("TextLabel", f)
            arrow.AnchorPoint = Vector2.new(1,0.5); arrow.Position = UDim2.new(0.98,0,0.5,0)
            arrow.Size = UDim2.new(0.05,0,0.5,0); arrow.BackgroundTransparency = 1
            arrow.Font = Enum.Font.GothamBold; arrow.Text = "▾"; arrow.TextScaled = true
            arrow.TextColor3 = Color3.fromRGB(200,80,80); arrow.TextTransparency = 0.4

            -- List container (below frame, inside TabPage)
            local listFrame = Instance.new("Frame", TabPage)
            listFrame.Size = UDim2.new(1,0,0,0); listFrame.BackgroundColor3 = Color3.fromRGB(20,6,6)
            listFrame.BackgroundTransparency = 0.35; listFrame.BorderSizePixel = 0; listFrame.ClipsDescendants = true
            listFrame.LayoutOrder = f.LayoutOrder + 0.5
            local lfc = Instance.new("UICorner", listFrame); lfc.CornerRadius = UDim.new(0,5)
            local lfs = Instance.new("UIStroke", listFrame); lfs.Color = Color3.fromRGB(160,20,20); lfs.Transparency = 0.6

            local listScroll = Instance.new("ScrollingFrame", listFrame)
            listScroll.Size = UDim2.new(1,0,1,0); listScroll.BackgroundTransparency = 1
            listScroll.BorderSizePixel = 0; listScroll.ScrollBarThickness = 3
            listScroll.ScrollBarImageColor3 = Color3.fromRGB(180,30,30); listScroll.Active = true

            local listLL = Instance.new("UIListLayout", listScroll)
            listLL.SortOrder = Enum.SortOrder.LayoutOrder; listLL.Padding = UDim.new(0,3)
            listLL.HorizontalAlignment = Enum.HorizontalAlignment.Center
            listLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                listScroll.CanvasSize = UDim2.fromOffset(0, listLL.AbsoluteContentSize.Y+6)
            end)
            local lpad = Instance.new("UIPadding", listScroll)
            lpad.PaddingTop=UDim.new(0,4);lpad.PaddingBottom=UDim.new(0,4)
            lpad.PaddingLeft=UDim.new(0,4);lpad.PaddingRight=UDim.new(0,4)

            local opened = false

            local function GetSelText()
                if #s.CurrentOption==0 then return "None"
                elseif #s.CurrentOption==1 then return s.CurrentOption[1]
                else return UnpackTable(s.CurrentOption) end
            end

            local function BuildList()
                for _,c in ipairs(listScroll:GetChildren()) do
                    if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
                end
                if s.SpecialType=="Player" then
                    s.Options = {}
                    for _,p in ipairs(Players:GetPlayers()) do table.insert(s.Options, p.Name) end
                end
                for _,opt in ipairs(s.Options) do
                    local ob = Instance.new("TextButton", listScroll)
                    ob.Size = UDim2.new(1,0,0,28); ob.BackgroundColor3 = Color3.fromRGB(30,8,8)
                    ob.BackgroundTransparency = table.find(s.CurrentOption,opt) and 0.3 or 0.6
                    ob.BorderSizePixel = 0; ob.Font = Enum.Font.Gotham
                    ob.Text = opt; ob.TextColor3 = Color3.fromRGB(230,200,200)
                    ob.TextScaled = true; ob.TextXAlignment = Enum.TextXAlignment.Left
                    local oc = Instance.new("UICorner", ob); oc.CornerRadius = UDim.new(0,4)
                    local op = Instance.new("UIPadding", ob); op.PaddingLeft = UDim.new(0,8)

                    ob.MouseEnter:Connect(function() Tween(ob,{BackgroundTransparency=0.2},0.1) end)
                    ob.MouseLeave:Connect(function() Tween(ob,{BackgroundTransparency=table.find(s.CurrentOption,opt) and 0.3 or 0.6},0.1) end)
                    ob.MouseButton1Click:Connect(function()
                        if s.MultipleOptions then
                            local idx = table.find(s.CurrentOption, opt)
                            if idx then table.remove(s.CurrentOption, idx)
                            else table.insert(s.CurrentOption, opt) end
                            pcall(s.Callback, s.CurrentOption)
                        else
                            s.CurrentOption = {opt}
                            pcall(s.Callback, opt)
                        end
                        DV.CurrentOption = s.CurrentOption
                        selLabel.Text = GetSelText()
                        BuildList()
                    end)
                end
            end

            local function Toggle()
                opened = not opened
                if opened then
                    local itemH = math.min(#s.Options, 5) * 31 + 10
                    BuildList()
                    Tween(listFrame, {Size=UDim2.new(1,0,0,itemH)}, 0.3, Enum.EasingStyle.Quint)
                    Tween(arrow, {Rotation=180}, 0.2)
                else
                    Tween(listFrame, {Size=UDim2.new(1,0,0,0)}, 0.3, Enum.EasingStyle.Quint)
                    Tween(arrow, {Rotation=0}, 0.2)
                end
            end

            HoverEffect(f, us)
            local btn = InteractBtn(f)
            btn.MouseButton1Click:Connect(Toggle)

            if s.SpecialType=="Player" then
                Players.PlayerAdded:Connect(function() if opened then BuildList() end end)
                Players.PlayerRemoving:Connect(function() if opened then BuildList() end end)
            end

            selLabel.Text = GetSelText()
            pcall(s.Callback, s.MultipleOptions and s.CurrentOption or (s.CurrentOption[1] or nil))

            function DV:Set(n)
                n=Kwargify(s,n); s=n
                if type(s.CurrentOption)=="string" then s.CurrentOption={s.CurrentOption} end
                selLabel.Text = GetSelText()
                BuildList()
                pcall(s.Callback, s.MultipleOptions and s.CurrentOption or (s.CurrentOption[1] or nil))
            end
            function DV:Destroy() f:Destroy(); listFrame:Destroy() end
            if flag then MergeUI.Options[flag] = DV end
            return DV
        end

        -- ── Keybind / Bind ────────────────────────────────────────────────
        function Tab:CreateBind(s, flag)
            s = Kwargify({Name="Bind",Description=nil,CurrentBind="Q",HoldToInteract=false,Callback=function()end,OnChangedCallback=function()end}, s)
            local BV = {Class="Keybind",IgnoreConfig=false,CurrentBind=s.CurrentBind,Active=false,Settings=s}
            local h = s.Description and 52 or 38
            local f,_,us = BaseFrame(h)
            TextEl(f, s.Name, 0.03, s.Description and 0.05 or 0.18, 0.6, s.Description and 0.35 or 0.65, true)
            if s.Description then TextEl(f, s.Description, 0.03, 0.52, 0.6, 0.35, false, 0.35) end

            local bindBox = Instance.new("TextBox", f)
            bindBox.AnchorPoint = Vector2.new(1,0.5); bindBox.Position = UDim2.new(0.97,0,0.5,0)
            bindBox.Size = UDim2.new(0.18,0,0.65,0); bindBox.BackgroundColor3 = Color3.fromRGB(30,8,8)
            bindBox.BackgroundTransparency = 0.4; bindBox.BorderSizePixel = 0
            bindBox.Font = Enum.Font.GothamBold; bindBox.Text = s.CurrentBind
            bindBox.TextColor3 = Color3.fromRGB(255,180,180); bindBox.TextScaled = true
            bindBox.ClearTextOnFocus = true; bindBox.ZIndex = f.ZIndex+3
            bindBox.TextXAlignment = Enum.TextXAlignment.Center
            local bbc = Instance.new("UICorner", bindBox); bbc.CornerRadius = UDim.new(0,4)
            local bbst = Instance.new("UIStroke", bindBox); bbst.Color = Color3.fromRGB(160,20,20); bbst.Transparency = 0.6

            local listening = false
            bindBox.Focused:Connect(function() listening = true; bindBox.Text = "" end)
            bindBox.FocusLost:Connect(function()
                listening = false
                if bindBox.Text=="" then bindBox.Text = s.CurrentBind end
            end)

            HoverEffect(f, us)

            UserInputService.InputBegan:Connect(function(inp, gpe)
                if gpe then return end
                if listening then
                    if inp.KeyCode ~= Enum.KeyCode.Unknown then
                        local kname = tostring(inp.KeyCode):split(".")[3]
                        bindBox.Text = kname; s.CurrentBind = kname; BV.CurrentBind = kname
                        pcall(s.OnChangedCallback, kname)
                        bindBox:ReleaseFocus()
                    end
                elseif s.CurrentBind and inp.KeyCode == Enum.KeyCode[s.CurrentBind] then
                    if not s.HoldToInteract then
                        BV.Active = not BV.Active
                        pcall(s.Callback, BV.Active)
                    else
                        local held = true
                        local con; con = inp.Changed:Connect(function(p)
                            if p=="UserInputState" then held=false con:Disconnect() end
                        end)
                        task.wait(0.1)
                        if held then
                            local loop; loop = RunService.Stepped:Connect(function()
                                if not held then pcall(s.Callback, false); loop:Disconnect()
                                else pcall(s.Callback, true) end
                            end)
                        end
                    end
                end
            end)

            function BV:Set(n) n=Kwargify(s,n) s=n bindBox.Text=s.CurrentBind BV.CurrentBind=s.CurrentBind end
            function BV:Destroy() f:Destroy() end
            if flag then MergeUI.Options[flag] = BV end
            return BV
        end

        Tab.CreateKeybind = Tab.CreateBind  -- alias

        -- ── Color Picker ──────────────────────────────────────────────────
        function Tab:CreateColorPicker(s, flag)
            s = Kwargify({Name="Color Picker",Color=Color3.fromRGB(220,30,30),Callback=function()end}, s)
            local CPV = {Class="Colorpicker",IgnoreConfig=false,Color=s.Color,Settings=s}

            local f,_,us = BaseFrame(38)
            TextEl(f, s.Name, 0.03, 0.18, 0.65, 0.65, true)

            local function ToHex(c) return string.format("#%02X%02X%02X",math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255)) end
            CPV.Color = s.Color

            -- Preview swatch
            local swatch = Instance.new("Frame", f)
            swatch.AnchorPoint = Vector2.new(1,0.5); swatch.Position = UDim2.new(0.97,0,0.5,0)
            swatch.Size = UDim2.new(0,32,0,22); swatch.BackgroundColor3 = s.Color; swatch.BorderSizePixel = 0
            local swc = Instance.new("UICorner", swatch); swc.CornerRadius = UDim.new(0,4)
            local sws = Instance.new("UIStroke", swatch); sws.Color = Color3.fromRGB(200,100,100); sws.Transparency = 0.5

            -- Expanded picker area
            local picker = Instance.new("Frame", TabPage)
            picker.Size = UDim2.new(1,0,0,0); picker.BackgroundColor3 = Color3.fromRGB(18,5,5)
            picker.BackgroundTransparency = 0.45; picker.BorderSizePixel = 0; picker.ClipsDescendants = true
            picker.LayoutOrder = f.LayoutOrder + 0.5
            local pic = Instance.new("UICorner", picker); pic.CornerRadius = UDim.new(0,5)
            local pis = Instance.new("UIStroke", picker); pis.Color = Color3.fromRGB(160,20,20); pis.Transparency = 0.6

            local opened = false
            local h,sv,vv = s.Color:ToHSV()

            -- Saturation/Value gradient
            local sat = Instance.new("ImageButton", picker)
            sat.Position = UDim2.new(0.03,0,0.06,0); sat.Size = UDim2.new(0.94,0,0.55,0)
            sat.BackgroundColor3 = Color3.fromHSV(h,1,1)
            sat.Image = "rbxassetid://11415645739"; sat.ImageTransparency = 0; sat.BorderSizePixel = 0; sat.ZIndex = 5
            local sacc = Instance.new("UICorner", sat); sacc.CornerRadius = UDim.new(0,4)

            local satThumb = Instance.new("Frame", sat)
            satThumb.Size = UDim2.new(0,10,0,10); satThumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
            satThumb.BorderSizePixel = 0; satThumb.ZIndex = 7
            local stc = Instance.new("UICorner", satThumb); stc.CornerRadius = UDim.new(0.5,0)
            local sts = Instance.new("UIStroke", satThumb); sts.Color = Color3.fromRGB(200,100,100); sts.Transparency = 0.3

            -- Hue slider
            local hueTrack = Instance.new("ImageLabel", picker)
            hueTrack.Position = UDim2.new(0.03,0,0.68,0); hueTrack.Size = UDim2.new(0.94,0,0.1,0)
            hueTrack.Image = "rbxassetid://6020299385"; hueTrack.BackgroundTransparency = 1; hueTrack.BorderSizePixel = 0; hueTrack.ZIndex = 5
            local htc = Instance.new("UICorner", hueTrack); htc.CornerRadius = UDim.new(0.5,0)

            local hueThumb = Instance.new("Frame", hueTrack)
            hueThumb.AnchorPoint = Vector2.new(0.5,0.5); hueThumb.Position = UDim2.new(h,0,0.5,0)
            hueThumb.Size = UDim2.new(0,14,1.4,0); hueThumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
            hueThumb.BorderSizePixel = 0; hueThumb.ZIndex = 6
            local htpc = Instance.new("UICorner", hueThumb); htpc.CornerRadius = UDim.new(0,4)

            -- Hex input
            local hexBox = Instance.new("TextBox", picker)
            hexBox.Position = UDim2.new(0.03,0,0.82,0); hexBox.Size = UDim2.new(0.6,0,0.12,0)
            hexBox.BackgroundColor3 = Color3.fromRGB(30,8,8); hexBox.BackgroundTransparency = 0.4; hexBox.BorderSizePixel = 0
            hexBox.Font = Enum.Font.Gotham; hexBox.Text = ToHex(s.Color)
            hexBox.TextColor3 = Color3.fromRGB(255,200,200); hexBox.TextScaled = true; hexBox.ZIndex = 6
            local hxc = Instance.new("UICorner", hexBox); hxc.CornerRadius = UDim.new(0,4)
            local hxs = Instance.new("UIStroke", hexBox); hxs.Color = Color3.fromRGB(160,20,20); hxs.Transparency = 0.6

            local function UpdateDisplay()
                local col = Color3.fromHSV(h,sv,vv)
                swatch.BackgroundColor3 = col
                sat.BackgroundColor3 = Color3.fromHSV(h,1,1)
                hueThumb.Position = UDim2.new(h,0,0.5,0)
                satThumb.Position = UDim2.new(sv,-5,1-vv,-5)
                hexBox.Text = ToHex(col)
                CPV.Color = col; s.Color = col
                pcall(s.Callback, col)
            end

            local satDrag, hueDrag = false, false
            local mouse = LocalPlayer:GetMouse()

            sat.MouseButton1Down:Connect(function() satDrag=true end)
            hueTrack.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=true end end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then satDrag=false; hueDrag=false end
            end)

            RunService.RenderStepped:Connect(function()
                if satDrag then
                    sv = math.clamp((mouse.X - sat.AbsolutePosition.X) / sat.AbsoluteSize.X, 0, 1)
                    vv = 1 - math.clamp((mouse.Y - sat.AbsolutePosition.Y) / sat.AbsoluteSize.Y, 0, 1)
                    UpdateDisplay()
                end
                if hueDrag then
                    h = math.clamp((mouse.X - hueTrack.AbsolutePosition.X) / hueTrack.AbsoluteSize.X, 0, 1)
                    UpdateDisplay()
                end
            end)

            hexBox.FocusLost:Connect(function()
                local r,g,b = hexBox.Text:match("^#?(%x%x)(%x%x)(%x%x)$")
                if r then
                    local col = Color3.fromRGB(tonumber(r,16),tonumber(g,16),tonumber(b,16))
                    h,sv,vv = col:ToHSV()
                    UpdateDisplay()
                else hexBox.Text = ToHex(s.Color) end
            end)

            local btn = InteractBtn(f)
            HoverEffect(f, us)
            btn.MouseButton1Click:Connect(function()
                opened = not opened
                if opened then
                    UpdateDisplay()
                    Tween(picker, {Size=UDim2.new(1,0,0,160)}, 0.35, Enum.EasingStyle.Quint)
                else
                    Tween(picker, {Size=UDim2.new(1,0,0,0)}, 0.35, Enum.EasingStyle.Quint)
                end
            end)

            function CPV:Set(n)
                n=Kwargify(s,n); s=n
                h,sv,vv = s.Color:ToHSV()
                UpdateDisplay()
            end
            function CPV:Destroy() f:Destroy(); picker:Destroy() end
            if flag then MergeUI.Options[flag] = CPV end
            return CPV
        end

        -- ── Config Builder ────────────────────────────────────────────────
        function Tab:BuildConfigSection()
            local inputName = nil
            local selectedCfg = nil

            Tab:CreateSection("Config Manager")
            Tab:CreateInput({
                Name = "Config Name",
                PlaceholderText = "Enter name...",
                Callback = function(v) inputName = v end
            })
            Tab:CreateButton({
                Name = "Save Config",
                Callback = function()
                    if not inputName or inputName=="" then
                        MergeUI:Notification({Title="Config",Content="Please enter a config name."})
                        return
                    end
                    Window:SaveConfig(inputName)
                    MergeUI:Notification({Title="Config",Content='Saved "'..inputName..'"'})
                    if cfgDrop then cfgDrop:Set({Options=Window:ListConfigs()}) end
                end
            })
            local cfgDrop = Tab:CreateDropdown({
                Name = "Select Config",
                Options = Window:ListConfigs(),
                CurrentOption = {},
                Callback = function(v) selectedCfg = v end
            })
            Tab:CreateButton({
                Name = "Load Config",
                Callback = function()
                    if not selectedCfg then MergeUI:Notification({Title="Config",Content="Select a config first."}) return end
                    local ok = Window:LoadConfig(selectedCfg)
                    MergeUI:Notification({Title="Config",Content=ok and 'Loaded "'..selectedCfg..'"' or "Failed to load config."})
                end
            })
            Tab:CreateButton({
                Name = "Refresh List",
                Callback = function()
                    cfgDrop:Set({Options=Window:ListConfigs()})
                end
            })
        end

        -- ── Theme Builder ─────────────────────────────────────────────────
        function Tab:BuildThemeSection()
            Tab:CreateSection("Theme Colors")
            local c1 = Tab:CreateColorPicker({Name="Color 1",Color=Color3.fromRGB(200,30,30),Callback=function(v)
                MergeUI.ThemeGradient = ColorSequence.new{ColorSequenceKeypoint.new(0,v),ColorSequenceKeypoint.new(0.5,c2 and c2.Color or v),ColorSequenceKeypoint.new(1,c3 and c3.Color or v)}
            end},"_ThemeC1")
            local c2 = Tab:CreateColorPicker({Name="Color 2",Color=Color3.fromRGB(160,20,40),Callback=function(v)
                MergeUI.ThemeGradient = ColorSequence.new{ColorSequenceKeypoint.new(0,c1 and c1.Color or v),ColorSequenceKeypoint.new(0.5,v),ColorSequenceKeypoint.new(1,c3 and c3.Color or v)}
            end},"_ThemeC2")
            local c3 = Tab:CreateColorPicker({Name="Color 3",Color=Color3.fromRGB(120,10,50),Callback=function(v)
                MergeUI.ThemeGradient = ColorSequence.new{ColorSequenceKeypoint.new(0,c1 and c1.Color or v),ColorSequenceKeypoint.new(0.5,c2 and c2.Color or v),ColorSequenceKeypoint.new(1,v)}
            end},"_ThemeC3")
        end

        return Tab
    end

    return Window
end

